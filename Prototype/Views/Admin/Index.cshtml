@model List<Prototype.Models.User>
@{
    var products = (List<Prototype.Models.Product>)ViewBag.Products;
}
<h2>Администрирование пользователей</h2>
@if (TempData["Error"] is not null)
{
    <p class="error">@TempData["Error"]</p>
}
<form method="post" asp-action="CreateUser">
    <label>Логин</label>
    <input name="login" />
    <label>Пароль</label>
    <input type="password" name="password" />
    <label>Роль</label>
    <select name="role">
        @foreach (var role in Enum.GetValues<UserRole>())
        {
            <option value="@role">@role</option>
        }
    </select>
    <button type="submit">Создать пользователя</button>
</form>
<table>
    <tr><th>Логин</th><th>Роль</th></tr>
    @foreach (var user in Model)
    {
        <tr><td>@user.Login</td><td>@user.Role</td>
            <td>
                <form method="post" asp-action="DeleteUser" asp-route-id="@user.Id"
                      onsubmit="return confirm('Вы уверены, что хотите удалить этого пользователя?');">
                    <button type="submit">Удалить</button>
                </form>
            </td>
        </tr>

    }
</table>
<h2>Справочник товаров</h2>
<form method="post" asp-action="CreateProduct">
    <label>Наименование</label>
    <input name="name" />
    <label>Описание</label>
    <input name="description" />
    <button type="submit">Добавить товар</button>
</form>
<table>
    <tr><th>Товар</th><th>Описание</th><th>Остаток</th></tr>
    @foreach (var product in products)
    {
        <tr><td>@product.Name</td>
            <td>@product.Description</td>
            <td>@product.QuantityInStock</td>
            <td>
                <form method="post" asp-action="DeleteProduct" asp-route-id="@product.Id" onsubmit="return confirm('Вы уверены, что хотите удалить этот товар?');">
                    <button type="submit">Удалить</button>
                </form>
            </td>        
        </tr>
    }
</table>